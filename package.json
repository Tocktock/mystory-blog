{
  "name": "",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "postbuild": "npx pagefind --site dist",
    "preview": "astro preview",
    "astro": "astro",
    "check": "astro check",
    "lint": "eslint . --ext .ts,.tsx,.astro --max-warnings=0",
    "lint:fix": "npm run lint -- --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "hero:photo": "node scripts/prepare_hero_photo.mjs",
    "hero:audit": "node scripts/audit_hero_images.mjs",
    "test:e2e": "npm run build && playwright test",
    "preaudit:lighthouse": "node scripts/audit/prepare-reports.mjs",
    "preaudit:axe": "node scripts/audit/prepare-reports.mjs",
    "preaudit:keyboard": "node scripts/audit/prepare-reports.mjs",
    "preaudit:links": "node scripts/audit/prepare-reports.mjs",
    "preaudit:persona-contract": "node scripts/audit/prepare-reports.mjs",
    "preaudit:publication-safety": "node scripts/audit/prepare-reports.mjs",
    "preaudit:responsive": "node scripts/audit/prepare-reports.mjs",
    "preaudit:static-links": "node scripts/audit/prepare-reports.mjs",
    "audit:lighthouse": "lighthouse http://127.0.0.1:4321 --chrome-flags=--headless --only-categories=performance,accessibility,seo --output=json --output=html --output-path=.reports/lighthouse/report",
    "audit:axe": "node scripts/audit/run-axe-check.mjs",
    "audit:keyboard": "node scripts/audit/run-keyboard-check.mjs",
    "audit:responsive": "node scripts/audit/run-responsive-check.mjs",
    "audit:links": "node scripts/audit/run-link-check.mjs",
    "audit:persona-contract": "node scripts/audit/run-persona-contract-check.mjs",
    "audit:publication-safety": "node scripts/audit/run-publication-safety-scan.mjs",
    "audit:static-links": "node scripts/audit/run-static-local-link-check.mjs",
    "audit:web": "npm run build && npm run audit:publication-safety && npm run audit:static-links && start-server-and-test \"npm run preview -- --host 127.0.0.1 --port 4321\" http://127.0.0.1:4321 \"npm run audit:lighthouse && npm run audit:axe && npm run audit:keyboard && npm run audit:responsive && npm run audit:links\""
  },
  "dependencies": {
    "@astrojs/mdx": "^7.0.2",
    "@astrojs/rss": "^4.0.19",
    "@astrojs/sitemap": "^3.7.3",
    "astro": "^7.0.6",
    "astro-og-canvas": "^0.13.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.61.1",
    "@typescript-eslint/eslint-plugin": "^8.62.1",
    "@typescript-eslint/parser": "^8.62.1",
    "axe-core": "^4.12.1",
    "eslint": "^9.39.4",
    "eslint-plugin-astro": "^1.7.0",
    "globals": "^17.7.0",
    "lighthouse": "^13.4.0",
    "linkinator": "^7.6.1",
    "pagefind": "^1.5.2",
    "prettier": "^3.9.4",
    "prettier-plugin-astro": "^0.14.1",
    "start-server-and-test": "^3.0.11",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1"
  }
}

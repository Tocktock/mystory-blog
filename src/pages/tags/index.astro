---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';
import { SITE_TITLE } from '../../consts';
import { collectTags } from '../../utils/tags';
import { routes } from '../../utils/routes';
import '../../styles/tags.css';

const posts = await getCollection('blog');
const tags = collectTags(posts);
---

<!doctype html>
<html lang="ko">
  <head>
    <BaseHead
      title={`태그 | ${SITE_TITLE}`}
      description="비슷한 기록들을 태그로 모았습니다."
      lang="ko"
    />
  </head>
  <body>
    <Header />
    <main class="tags-page" aria-labelledby="tags-title">
      <section class="tags-page__intro">
        <h1 id="tags-title">태그</h1>
        <p>비슷한 기록들을 태그로 모아봤습니다.</p>
      </section>
      <ul class="tags-page__list">
        {
          tags.map((tag) => (
            <li>
              <a href={routes.tag(tag.slug)}>
                <span class="tags-page__label">{tag.label}</span>
                <span class="tags-page__count" aria-label={`${tag.posts.length} records`}>
                  {tag.posts.length}
                </span>
              </a>
            </li>
          ))
        }
      </ul>
    </main>
    <Footer />
  </body>
</html>

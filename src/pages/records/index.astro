---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';
import { getCollection } from 'astro:content';
import FormattedDate from '../../components/FormattedDate.astro';
import { Image } from 'astro:assets';
import placeholder2 from '../../assets/placeholders/blog-placeholder-2.jpg';
import placeholder3 from '../../assets/placeholders/blog-placeholder-3.jpg';
import placeholder4 from '../../assets/placeholders/blog-placeholder-4.jpg';
import placeholder5 from '../../assets/placeholders/blog-placeholder-5.jpg';
import { categoryList, getCategory } from '../../data/categories';
import { getSeries } from '../../data/series';
import { getPostHeroImageAlt } from '../../utils/postImages';
import { routes } from '../../utils/routes';

const defaultImages = [placeholder2, placeholder3, placeholder4, placeholder5];

const getRandomImage = () => {
  const randomIndex = Math.floor(Math.random() * defaultImages.length);
  return defaultImages[randomIndex];
};

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const activeCategorySlugs = new Set(posts.map((post) => post.data.category));
const activeCategories = categoryList.filter((category) => activeCategorySlugs.has(category.slug));
---

<!doctype html>
<html lang="ko">
  <head>
    <BaseHead
      title={`기록 | ${SITE_TITLE}`}
      description="기술, 일상, 생각, 프로젝트, 만냥구름의 기록을 모았습니다."
      lang="ko"
    />
  </head>
  <body>
    <Header />
    <main>
      <section class="records-index" aria-labelledby="records-title">
        <header class="records-index__header">
          <p class="records-index__eyebrow">Records</p>
          <h1 id="records-title" class="page-title">기록</h1>
          <p class="records-index__description">
            기술, 일상, 생각, 프로젝트, 만냥구름의 기록을 모았습니다.
            {SITE_DESCRIPTION}
          </p>
        </header>

        <nav class="records-index__categories" aria-label="기록 카테고리">
          <a
            class="records-index__category-link records-index__category-link--active"
            href={routes.records}
          >
            전체
          </a>
          {
            activeCategories.map((category) => (
              <a class="records-index__category-link" href={routes.category(category.slug)}>
                {category.label}
              </a>
            ))
          }
        </nav>

        <ul class="record-grid">
          {
            posts.map((post, index) => {
              const isFeatured = index === 0;
              const category = getCategory(post.data.category);
              const seriesEntry = getSeries(post.data.series);

              return (
                <li class:list={['record-card', { 'record-card--featured': isFeatured }]}>
                  <a href={routes.record(post.id)}>
                    <Image
                      src={post.data.heroImage ?? getRandomImage()}
                      alt={getPostHeroImageAlt(post.data)}
                      width={isFeatured ? 960 : 480}
                      widths={isFeatured ? [720, 960, 1200] : [480, 720, 960]}
                      sizes={
                        isFeatured
                          ? '(max-width: 960px) 100vw, 960px'
                          : '(max-width: 960px) 100vw, 480px'
                      }
                      loading={index === 0 ? 'eager' : 'lazy'}
                      decoding="async"
                      class="record-card__image"
                    />
                    <div class="record-card__body">
                      <div class="record-card__meta">
                        <span class="record-card__category">{category.label}</span>
                        {seriesEntry && (
                          <span class="record-card__series">{seriesEntry.title}</span>
                        )}
                      </div>
                      <h2 class="record-card__title">{post.data.title}</h2>
                      <p class="record-card__description">{post.data.description}</p>
                      <p class="record-card__date">
                        <FormattedDate date={post.data.pubDate} />
                      </p>
                      {post.data.tags.length > 0 && (
                        <ul class="record-card__tags">
                          {post.data.tags.map((tag) => (
                            <li>{tag}</li>
                          ))}
                        </ul>
                      )}
                    </div>
                  </a>
                </li>
              );
            })
          }
        </ul>
      </section>
      <Footer />
    </main>
  </body>
</html>

<style>
  main {
    width: 960px;
  }

  .records-index {
    padding: 1.5rem 0 0;
  }

  .records-index__header {
    max-width: 42rem;
    margin: 0 auto 2rem;
    text-align: center;
  }

  .records-index__eyebrow {
    margin: 0 0 0.35rem;
    color: var(--accent);
    font-size: 0.9rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .page-title {
    margin: 0 0 1rem;
    font-size: clamp(2.4rem, 4vw, 3.2rem);
    text-align: center;
  }

  .records-index__description {
    margin: 0;
    color: rgb(var(--gray));
    line-height: 1.75;
    text-wrap: balance;
  }

  .records-index__categories {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.6rem;
    margin: 0 0 2rem;
  }

  .records-index__category-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.45rem 0.8rem;
    border-radius: 999px;
    border: 1px solid rgba(var(--gray-light), 0.5);
    background: var(--surface-elevated);
    color: rgb(var(--gray-dark));
    font-size: 0.95rem;
    font-weight: 700;
    text-decoration: none;
  }

  .records-index__category-link:hover,
  .records-index__category-link:focus-visible,
  .records-index__category-link--active {
    border-color: var(--accent);
    color: var(--accent);
  }

  .record-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 2rem;
    list-style-type: none;
    margin: 0;
    padding: 0;
  }

  .record-card {
    width: calc(50% - 1rem);
  }

  .record-card--featured {
    width: 100%;
  }

  .record-card a {
    display: block;
    height: 100%;
    padding: 0.5rem;
    text-decoration: none;
    border-radius: 16px;
    background: var(--surface-elevated);
    color: rgb(var(--gray-dark));
    box-shadow: 0 0 0 1px rgba(var(--gray-light), 0.18);
    transition:
      box-shadow 0.2s ease,
      transform 0.2s ease,
      background-color 0.2s ease;
  }

  .record-card a:focus-visible,
  .record-card a:hover {
    box-shadow: var(--box-shadow);
    background-color: rgba(var(--gray-light), 0.12);
    transform: translateY(-2px);
  }

  .record-card__image {
    display: block;
    width: 100%;
    margin-bottom: 0.75rem;
    border-radius: 14px;
  }

  .record-card__body {
    padding: 0.25rem 0.25rem 0.5rem;
  }

  .record-card__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    margin-bottom: 0.65rem;
  }

  .record-card__category,
  .record-card__series {
    display: inline-flex;
    align-items: center;
    padding: 0.2rem 0.5rem;
    border-radius: 999px;
    font-size: 0.78rem;
    font-weight: 700;
    line-height: 1.2;
  }

  .record-card__category {
    background: rgba(var(--accent-rgb), 0.12);
    color: var(--accent-dark);
  }

  .record-card__series {
    background: rgba(var(--gray-light), 0.26);
    color: rgb(var(--gray-dark));
  }

  .record-card__title {
    margin: 0 0 0.5rem;
    color: rgb(var(--black));
    line-height: 1.2;
  }

  .record-card__description {
    margin: 0 0 0.75rem;
    color: rgb(var(--gray-dark));
    font-size: 0.98rem;
    line-height: 1.6;
  }

  .record-card__date {
    margin: 0;
    color: rgb(var(--gray));
    font-size: 0.95rem;
  }

  .record-card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin: 0.75rem 0 0;
    padding: 0;
    list-style: none;
  }

  .record-card__tags li {
    display: inline-flex;
    align-items: center;
    padding: 0.25rem 0.5rem;
    border-radius: 999px;
    background: rgba(var(--accent-rgb), 0.12);
    color: var(--accent-dark);
    font-size: 0.85rem;
    font-weight: 600;
  }

  @media (max-width: 960px) {
    main {
      width: 100%;
    }

    .record-grid {
      gap: 1.25rem;
    }

    .record-card {
      width: 100%;
    }
  }
</style>

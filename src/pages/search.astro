---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE } from '../consts';
import '../styles/search.css';
---

<!doctype html>
<html lang="ko">
  <head>
    <BaseHead
      title={`기록 찾기 | ${SITE_TITLE}`}
      description="기술 노트, 일상 기록, 만냥구름 이야기까지 기록실에서 찾아봅니다."
      lang="ko"
    />
    <link rel="stylesheet" href="/pagefind/pagefind-ui.css" />
  </head>
  <body>
    <Header />
    <main class="search-page" aria-labelledby="search-title">
      <section class="search-page__intro">
        <p class="search-page__eyebrow">Search Drawer</p>
        <h1 id="search-title">기록 찾기</h1>
        <p>
          기억나는 단어를 입력해보세요. 기술 노트, 일상 기록, 만냥구름 이야기까지 함께 찾아봅니다.
        </p>
      </section>
      <div id="search" class="search-page__results"></div>
    </main>
    <Footer />
    <script type="module" is:inline>
      const initSearch = async () => {
        try {
          const module = await import('/pagefind/pagefind-ui.js');
          const PagefindUI = module?.PagefindUI ?? window.PagefindUI;
          if (typeof PagefindUI !== 'function') {
            throw new Error('PagefindUI script did not expose the PagefindUI constructor.');
          }
          new PagefindUI({
            element: '#search',
            bundlePath: '/pagefind/',
            showImages: true,
            translations: {
              placeholder: '기록실에서 찾아볼게요…',
              zero_results: '만냥구름도 못 찾았어요. 다른 단어로 다시 찾아볼까요?',
              clear_search: '검색어 지우기',
              load_more: '더 보기',
              search_label: '기록 검색',
            },
          });
        } catch (error) {
          const container = document.querySelector('#search');
          if (container) {
            container.innerHTML =
              '<div class="search-page__fallback"><p><strong>검색 서랍을 아직 열 수 없어요.</strong></p><p>빌드 후 생성되는 Pagefind 색인이 필요합니다. <code>npm run build</code>를 실행한 뒤 다시 확인해주세요.</p></div>';
          }
          console.warn('Pagefind UI failed to load. Did you run `npm run build`?', error);
        }
      };

      initSearch();
    </script>
  </body>
</html>

---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/search.css';
import { buildWebPageJsonLd } from '../utils/jsonld';

const siteURL = Astro.site ? new URL(Astro.site) : Astro.url;
const canonicalURL = new URL(Astro.url.pathname, siteURL).toString();
const pageJsonLd = buildWebPageJsonLd({
  canonicalUrl: canonicalURL,
  title: 'Search',
  description: 'Search Ji Yong\'s blog posts',
  lang: 'ko',
  type: 'SearchResultsPage',
});
---

<!doctype html>
<html lang="ko">
  <head>
    <BaseHead title="Search" description="Search Ji Yong’s blog posts" lang="ko" />
    <script type="application/ld+json" is:inline set:html={JSON.stringify(pageJsonLd)} />
    <link rel="stylesheet" href="/pagefind/pagefind-ui.css" />
  </head>
  <body>
    <Header />
    <main id="main-content" data-pagefind-body class="search-page" aria-labelledby="search-title">
      <section class="search-page__intro">
        <h1 id="search-title">Search</h1>
        <p>Find posts by keyword or filter results using the built-in Pagefind interface.</p>
      </section>
      <label class="search-page__label" for="search-input">Search keyword</label>
      <div id="search" class="search-page__results"></div>
    </main>
    <Footer />
    <script type="module" is:inline>
      const attachSearchInputLabel = () => {
        const searchRoot = document.querySelector('#search');
        const input = searchRoot?.querySelector('input[type="search"], input');
        if (input instanceof HTMLInputElement) {
          input.id = 'search-input';
          input.setAttribute('aria-describedby', 'search-title');
        }
      };

      const initSearch = async () => {
        try {
          const module = await import('/pagefind/pagefind-ui.js');
          const PagefindUI = module?.PagefindUI ?? window.PagefindUI;
          if (typeof PagefindUI !== 'function') {
            throw new Error('PagefindUI script did not expose the PagefindUI constructor.');
          }

          new PagefindUI({
            element: '#search',
            bundlePath: '/pagefind/',
            showImages: true,
            translations: {
              placeholder: '검색어를 입력하세요…',
              zero_results: '일치하는 결과가 없습니다.',
            },
          });

          const params = new URLSearchParams(window.location.search);
          const initialQuery = params.get('q')?.trim();

          const hydrateInput = () => {
            attachSearchInputLabel();
            if (!initialQuery) return;
            const searchRoot = document.querySelector('#search');
            const input = searchRoot?.querySelector('input[type="search"], input');
            if (input instanceof HTMLInputElement && input.value !== initialQuery) {
              input.value = initialQuery;
              input.dispatchEvent(new Event('input', { bubbles: true }));
            }
          };

          requestAnimationFrame(hydrateInput);
          setTimeout(hydrateInput, 200);
        } catch (error) {
          const container = document.querySelector('#search');
          if (container) {
            container.innerHTML =
              '<p class="search-page__fallback">Search index not found. Run <code>npm run build</code> to generate Pagefind assets.</p>';
          }
          console.warn('Pagefind UI failed to load. Did you run `npm run build`?', error);
        }
      };

      initSearch();
    </script>
  </body>
</html>

---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE } from '../consts';
import { uiCopy } from '../data/uiCopy';
import '../styles/search.css';
---

<!doctype html>
<html lang="ko">
  <head>
    <BaseHead
      title={`기록 찾기 | ${SITE_TITLE}`}
      description="기술 노트, 일상 기록, 만냥구름 이야기까지 기록실에서 찾아봅니다."
      lang="ko"
    />
    <link rel="stylesheet" href="/pagefind/pagefind-ui.css" />
  </head>
  <body>
    <Header />
    <main class="search-page" aria-labelledby="search-title">
      <section class="search-page__intro">
        <p class="search-page__eyebrow">{uiCopy.searchDrawer}</p>
        <h1 id="search-title">기록 찾기</h1>
        <p>
          기억나는 단어를 입력해보세요. 기술 노트, 일상 기록, 만냥구름 이야기까지 함께 찾아봅니다.
        </p>
      </section>
      <div
        id="search"
        class="search-page__results"
        data-zero-results={uiCopy.searchNoResults}
        data-fallback-title={uiCopy.searchUnavailableTitle}
        data-fallback-description={uiCopy.searchUnavailableDescription}
      >
        <noscript>
          <form class="search-page__noscript-form" action="/search/" method="get" role="search">
            <label for="fallback-search">검색어</label>
            <div>
              <input
                id="fallback-search"
                name="q"
                type="search"
                placeholder="기록실에서 찾아볼게요"
              />
              <button type="submit">검색</button>
            </div>
          </form>
          <p class="search-page__noscript-note">
            검색 결과를 보려면 JavaScript가 필요합니다. 대신 기록과 시리즈를 열어보거나 검색 서랍을
            다시 사용할 수 있을 때 찾아볼 수 있습니다.
          </p>
        </noscript>
      </div>
    </main>
    <Footer />
    <script type="module" is:inline>
      const SEARCH_QUERY_PARAM = 'q';
      const SEARCH_INPUT_ID = 'record-room-search-input';

      const getSearchTermFromURL = () => {
        const params = new URLSearchParams(window.location.search);
        return params.get(SEARCH_QUERY_PARAM)?.trim() ?? '';
      };

      const syncURLToSearchTerm = (term) => {
        const url = new URL(window.location.href);
        const normalizedTerm = term.trim();

        if (normalizedTerm) {
          url.searchParams.set(SEARCH_QUERY_PARAM, normalizedTerm);
        } else {
          url.searchParams.delete(SEARCH_QUERY_PARAM);
        }

        window.history.replaceState({}, '', url);
      };

      const ensureVisibleSearchLabel = (container) => {
        const input = container?.querySelector('.pagefind-ui__search-input');
        if (!(input instanceof HTMLInputElement)) return;

        if (!input.id) {
          input.id = SEARCH_INPUT_ID;
        }
        input.setAttribute('aria-label', '검색어');

        const form = input.closest('form');
        if (!form || form.querySelector(`label[for="${input.id}"]`)) return;

        const label = document.createElement('label');
        label.className = 'search-page__input-label';
        label.htmlFor = input.id;
        label.textContent = '검색어';
        form.insertBefore(label, input);
      };

      const initSearch = async () => {
        try {
          const module = await import('/pagefind/pagefind-ui.js');
          const PagefindUI = module?.PagefindUI ?? window.PagefindUI;
          if (typeof PagefindUI !== 'function') {
            throw new Error('PagefindUI script did not expose the PagefindUI constructor.');
          }
          const search = new PagefindUI({
            element: '#search',
            bundlePath: '/pagefind/',
            showImages: true,
            translations: {
              placeholder: '기록실에서 찾아볼게요…',
              zero_results:
                document.querySelector('#search')?.dataset.zeroResults ??
                '비어 있는 서랍입니다. 다른 단어로 다시 찾아볼 수 있습니다.',
              clear_search: '검색어 지우기',
              load_more: '더 보기',
              search_label: '기록 검색',
            },
          });

          const initialTerm = getSearchTermFromURL();
          if (initialTerm) {
            search.triggerSearch(initialTerm);
          }

          const container = document.querySelector('#search');
          requestAnimationFrame(() => ensureVisibleSearchLabel(container));
          const searchLabelObserver = new MutationObserver(() =>
            ensureVisibleSearchLabel(container),
          );
          if (container) {
            searchLabelObserver.observe(container, { childList: true, subtree: true });
          }
          container?.addEventListener('input', (event) => {
            const input = event.target;
            if (input instanceof HTMLInputElement && input.matches('.pagefind-ui__search-input')) {
              syncURLToSearchTerm(input.value);
            }
          });
          container?.addEventListener('click', (event) => {
            const button = event.target;
            if (
              button instanceof HTMLButtonElement &&
              button.matches('.pagefind-ui__search-clear')
            ) {
              requestAnimationFrame(() => syncURLToSearchTerm(''));
            }
          });
        } catch (error) {
          const container = document.querySelector('#search');
          if (container) {
            const fallback = document.createElement('div');
            const title = document.createElement('p');
            const strong = document.createElement('strong');
            const description = document.createElement('p');
            fallback.className = 'search-page__fallback';
            strong.textContent =
              container.dataset.fallbackTitle ?? '검색 서랍을 아직 열 수 없어요.';
            description.textContent =
              container.dataset.fallbackDescription ??
              '빌드 후 생성되는 Pagefind 색인이 필요합니다.';
            title.append(strong);
            fallback.append(title, description);
            container.replaceChildren(fallback);
          }
          console.warn('Pagefind UI failed to load. Did you run `npm run build`?', error);
        }
      };

      initSearch();
    </script>
  </body>
</html>

---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import SeriesCard from '../../components/records/SeriesCard.astro';
import { getCollection } from 'astro:content';
import { SITE_TITLE } from '../../consts';
import { seriesList } from '../../data/series';
import { uiCopy } from '../../data/uiCopy';

const posts = await getCollection('blog');
const seriesCards = seriesList
  .map((item) => ({
    ...item,
    posts: posts.filter((post) => post.data.series === item.slug),
  }))
  .filter((item) => item.posts.length > 0);
---

<!doctype html>
<html lang="ko">
  <head>
    <BaseHead
      title={`시리즈 | ${SITE_TITLE}`}
      description="기록실 책장에 꽂아둔 긴 기록들을 모았습니다."
      lang="ko"
    />
  </head>
  <body>
    <Header />
    <main class="series-page" aria-labelledby="series-title">
      <header class="series-page__header">
        <p class="series-page__eyebrow">{uiCopy.bookshelf}</p>
        <h1 id="series-title">시리즈</h1>
        <p>
          기록실 책장에 꽂아둔 긴 기록들입니다. AI, Backend, Agent, 그리고 만냥구름의 이야기를
          흐름으로 정리합니다.
        </p>
      </header>

      <section aria-label="시리즈 목록">
        <div class="series-grid">
          {seriesCards.map((item) => <SeriesCard seriesItem={item} count={item.posts.length} />)}
        </div>
      </section>
      <Footer />
    </main>
  </body>
</html>

<style>
  .series-page {
    width: 960px;
  }

  .series-page__header {
    max-width: 42rem;
    margin: 0 auto 2.5rem;
    text-align: center;
  }

  .series-page__eyebrow {
    margin: 0 0 0.35rem;
    color: var(--accent);
    font-size: 0.9rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .series-page__header h1 {
    margin-bottom: 1rem;
  }

  .series-page__header p {
    margin: 0;
    color: rgb(var(--gray));
    line-height: 1.75;
    text-wrap: balance;
  }

  .series-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1.25rem;
  }

  @media (max-width: 960px) {
    .series-page {
      width: 100%;
    }
  }
</style>

---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../../consts';
import { getCollection } from 'astro:content';
import FormattedDate from '../../components/FormattedDate.astro';
import { Image } from 'astro:assets';
import placeholder2 from '../../assets/placeholders/blog-placeholder-2.jpg';
import placeholder3 from '../../assets/placeholders/blog-placeholder-3.jpg';
import placeholder4 from '../../assets/placeholders/blog-placeholder-4.jpg';
import placeholder5 from '../../assets/placeholders/blog-placeholder-5.jpg';
import { buildItemListJsonLd, buildWebPageJsonLd } from '../../utils/jsonld';

const defaultImages = [placeholder2, placeholder3, placeholder4, placeholder5];

const normalizeToken = (value: string) => value.trim().toLowerCase();

const getFallbackImage = (postId: string) => {
  const hash = [...postId].reduce((acc, char) => acc + char.charCodeAt(0), 0);
  return defaultImages[hash % defaultImages.length];
};

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const lifeTopicSlugs = new Set(['running', 'meta']);
const lifeTagSlugs = new Set(['running', 'marathon', 'habit', 'diary', 'journal', 'life', 'daily']);

const isLifePost = (post: CollectionEntry<'blog'>) => {
  const topic = normalizeToken(post.id.split('/')[0] ?? '');
  const tags = post.data.tags.map(normalizeToken);
  return lifeTopicSlugs.has(topic) || tags.some((tag) => lifeTagSlugs.has(tag));
};

const featuredPost = posts[0];
const techPosts = posts.filter((post) => post.id !== featuredPost?.id && !isLifePost(post));
const lifePosts = posts.filter((post) => post.id !== featuredPost?.id && isLifePost(post));

const siteURL = Astro.site ? new URL(Astro.site) : Astro.url;
const canonicalURL = new URL(Astro.url.pathname, siteURL).toString();

const collectionJsonLd = buildWebPageJsonLd({
  canonicalUrl: canonicalURL,
  title: 'Blog',
  description: 'Browse Ji Yong\'s technical notes and everyday stories.',
  lang: 'ko',
  type: 'CollectionPage',
});

const listJsonLd = buildItemListJsonLd({
  name: 'Blog Posts',
  items: posts.map((post) => ({
    name: post.data.title,
    url: new URL(`/blog/${post.id}/`, siteURL).toString(),
    description: post.data.description,
  })),
});
---

<!doctype html>
<html lang="ko">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} lang="ko" />
    <script type="application/ld+json" is:inline set:html={JSON.stringify(collectionJsonLd)} />
    <script type="application/ld+json" is:inline set:html={JSON.stringify(listJsonLd)} />
    <style>
      main {
        width: 960px;
      }
      .blog-index {
        padding: 1.5rem 0 0;
      }
      .page-title {
        margin: 0;
        font-size: clamp(2rem, 4vw, 2.8rem);
        text-align: center;
      }
      .page-description {
        margin: 0.9rem auto 1.5rem;
        max-width: 56ch;
        text-align: center;
        color: rgb(var(--gray));
      }
      .blog-index__jump-links {
        display: flex;
        justify-content: center;
        gap: 0.75rem;
        flex-wrap: wrap;
        margin-bottom: 1.8rem;
      }
      .blog-index__jump-links a {
        display: inline-flex;
        align-items: center;
        padding: 0.45rem 0.9rem;
        border: 1px solid rgba(var(--black), 0.28);
        border-radius: 999px;
        text-decoration: none;
        color: rgb(var(--black));
      }
      .blog-section {
        margin-top: 2.4rem;
      }
      .blog-section:first-of-type {
        margin-top: 0;
      }
      .blog-section__header {
        margin-bottom: 1rem;
      }
      .blog-section__title {
        margin: 0;
        font-size: clamp(1.55rem, 2.6vw, 2rem);
      }
      .blog-section__description {
        margin: 0.4rem 0 0;
        color: rgb(var(--gray));
      }
      .post-grid {
        display: flex;
        flex-wrap: wrap;
        gap: 2rem;
        list-style-type: none;
        margin: 0;
        padding: 0;
      }
      .post-card {
        width: calc(50% - 1rem);
      }
      .post-card--featured {
        width: 100%;
      }
      .post-card a {
        display: block;
        padding: 0.5rem;
        text-decoration: none;
        border-radius: 12px;
        background: var(--surface-elevated);
        color: rgb(var(--gray-dark));
        box-shadow: 0 0 0 1px rgba(var(--gray-light), 0.18);
        transition: box-shadow 0.2s ease, transform 0.2s ease, background-color 0.2s ease;
      }
      .post-card a:focus-visible,
      .post-card a:hover {
        box-shadow: var(--box-shadow);
        background-color: rgba(var(--gray-light), 0.12);
        transform: translateY(-2px);
      }
      .post-card__image {
        display: block;
        width: 100%;
        margin-bottom: 0.75rem;
        border-radius: 12px;
      }
      .post-card__title {
        margin: 0 0 0.5rem;
        color: rgb(var(--black));
        line-height: 1.2;
      }
      .post-card__date {
        margin: 0;
        color: rgb(var(--gray));
        font-size: 0.95rem;
      }
      .post-card__tags {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
        margin: 0.75rem 0 0;
        padding: 0;
        list-style: none;
      }
      .post-card__tags li {
        display: inline-flex;
        align-items: center;
        padding: 0.25rem 0.5rem;
        border-radius: 999px;
        border: 1px solid rgba(var(--black), 0.45);
        background: transparent;
        color: rgb(var(--black));
        font-size: 0.85rem;
        font-weight: 600;
      }
      @media (max-width: 960px) {
        main {
          width: 100%;
        }
        .post-grid {
          gap: 1.25rem;
        }
        .post-card {
          width: 100%;
        }
      }
    </style>
  </head>
  <body>
    <Header />
    <main id="main-content" data-pagefind-body>
      <section class="blog-index" aria-labelledby="blog-title">
        <h1 id="blog-title" class="page-title">Blog</h1>
        <p class="page-description">
          Technical deep-dives and everyday stories, organized so you can jump straight to what you
          want to read.
        </p>
        <nav class="blog-index__jump-links" aria-label="Browse blog sections">
          <a href="#featured">Featured</a>
          <a href="#tech-notes">Tech Notes</a>
          <a href="#daily-stories">Everyday Stories</a>
        </nav>

        {
          featuredPost && (
            <section id="featured" class="blog-section" aria-labelledby="featured-title">
              <header class="blog-section__header">
                <h2 id="featured-title" class="blog-section__title">Featured</h2>
                <p class="blog-section__description">The most recent post.</p>
              </header>
              <ul class="post-grid">
                <li class="post-card post-card--featured">
                  <a href={`/blog/${featuredPost.id}/`}>
                    <Image
                      src={featuredPost.data.heroImage ?? getFallbackImage(featuredPost.id)}
                      alt=""
                      width={960}
                      widths={[720, 960, 1200]}
                      sizes="(max-width: 960px) 100vw, 960px"
                      loading="eager"
                      decoding="async"
                      class="post-card__image"
                    />
                    <h3 class="post-card__title">{featuredPost.data.title}</h3>
                    <p class="post-card__date">
                      <FormattedDate date={featuredPost.data.pubDate} lang="ko" />
                    </p>
                    {featuredPost.data.tags.length > 0 && (
                      <ul class="post-card__tags">
                        {featuredPost.data.tags.map((tag) => (
                          <li>{tag}</li>
                        ))}
                      </ul>
                    )}
                  </a>
                </li>
              </ul>
            </section>
          )
        }

        <section id="tech-notes" class="blog-section" aria-labelledby="tech-notes-title">
          <header class="blog-section__header">
            <h2 id="tech-notes-title" class="blog-section__title">Tech Notes</h2>
            <p class="blog-section__description">Engineering posts, tooling write-ups, and technical lessons.</p>
          </header>
          <ul class="post-grid">
            {techPosts.map((post) => (
              <li class="post-card">
                <a href={`/blog/${post.id}/`}>
                  <Image
                    src={post.data.heroImage ?? getFallbackImage(post.id)}
                    alt=""
                    width={480}
                    widths={[480, 720, 960]}
                    sizes="(max-width: 960px) 100vw, 480px"
                    loading="lazy"
                    decoding="async"
                    class="post-card__image"
                  />
                  <h3 class="post-card__title">{post.data.title}</h3>
                  <p class="post-card__date">
                    <FormattedDate date={post.data.pubDate} lang="ko" />
                  </p>
                  {post.data.tags.length > 0 && (
                    <ul class="post-card__tags">
                      {post.data.tags.map((tag) => (
                        <li>{tag}</li>
                      ))}
                    </ul>
                  )}
                </a>
              </li>
            ))}
          </ul>
        </section>

        <section id="daily-stories" class="blog-section" aria-labelledby="daily-stories-title">
          <header class="blog-section__header">
            <h2 id="daily-stories-title" class="blog-section__title">Everyday Stories</h2>
            <p class="blog-section__description">Personal notes, routines, and day-to-day reflections.</p>
          </header>
          <ul class="post-grid">
            {lifePosts.map((post) => (
              <li class="post-card">
                <a href={`/blog/${post.id}/`}>
                  <Image
                    src={post.data.heroImage ?? getFallbackImage(post.id)}
                    alt=""
                    width={480}
                    widths={[480, 720, 960]}
                    sizes="(max-width: 960px) 100vw, 480px"
                    loading="lazy"
                    decoding="async"
                    class="post-card__image"
                  />
                  <h3 class="post-card__title">{post.data.title}</h3>
                  <p class="post-card__date">
                    <FormattedDate date={post.data.pubDate} lang="ko" />
                  </p>
                  {post.data.tags.length > 0 && (
                    <ul class="post-card__tags">
                      {post.data.tags.map((tag) => (
                        <li>{tag}</li>
                      ))}
                    </ul>
                  )}
                </a>
              </li>
            ))}
          </ul>
        </section>
      </section>
    </main>
    <Footer />
  </body>
</html>

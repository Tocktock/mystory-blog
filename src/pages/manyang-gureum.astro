---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import EmptyState from '../components/common/EmptyState.astro';
import CatGallery from '../components/cats/CatGallery.astro';
import CatProfileCard from '../components/cats/CatProfileCard.astro';
import { SITE_TITLE } from '../consts';
import { cats } from '../data/cats';
import { catPhotos } from '../data/catGallery';
import { uiCopy } from '../data/uiCopy';
import { routes } from '../utils/routes';

const PAGE_TITLE = `만냥구름 | ${SITE_TITLE}`;
const PAGE_DESCRIPTION =
  '기록실을 함께 쓰는 만냥이와 구름이를 통해 관찰, 돌봄, 원인 이해를 차분히 남기는 공간입니다.';

const featuredPhoto = catPhotos.find((photo) => photo.featured) ?? catPhotos[0];
const observationNotes = [
  {
    title: '먼저 바라보기',
    description: '행동을 바로 판단하기보다 반복되는 표정, 자리, 움직임을 먼저 봅니다.',
  },
  {
    title: '원인을 이해하기',
    description: '불편한 행동에도 이유가 있다고 보고, 환경과 습관을 함께 살핍니다.',
  },
  {
    title: '돌봄을 기록으로 남기기',
    description: '작은 해결과 따뜻한 순간을 기록해 다음 선택의 기준으로 삼습니다.',
  },
] as const;

const observationPosts = (await getCollection('blog'))
  .filter((post) => post.data.category === 'cats')
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 4);
---

<!doctype html>
<html lang="ko">
  <head>
    <BaseHead title={PAGE_TITLE} description={PAGE_DESCRIPTION} lang="ko" />
  </head>
  <body>
    <Header />
    <main class="manyang-page" aria-labelledby="manyang-gureum-title">
      <header class="manyang-hero">
        <div class="manyang-hero__content">
          <p class="manyang-hero__eyebrow">Manyang & Gureum</p>
          <h1 id="manyang-gureum-title">만냥구름</h1>
          <p>
            기록실을 함께 쓰는 두 고양이입니다. 귀여운 장면만 모으기보다, 작은 변화와 불편의 이유를
            관찰하고 돌보는 방식을 함께 남깁니다.
          </p>
          <div class="manyang-hero__actions" aria-label="만냥구름 페이지 섹션 이동">
            <a href="#cat-profiles">둘 소개 보기</a>
            <a href="#cat-gallery">사진첩 보기</a>
            <a href="#cat-notes">관찰일지 보기</a>
          </div>
        </div>

        {
          featuredPhoto && (
            <figure class="manyang-hero__photo">
              <Image
                src={featuredPhoto.image}
                alt={featuredPhoto.alt}
                widths={[420, 640, 820, 960, 1280]}
                sizes="(max-width: 860px) 100vw, 520px"
                loading="eager"
                decoding="async"
              />
              <figcaption>{featuredPhoto.caption}</figcaption>
            </figure>
          )
        }
      </header>

      <section
        class="observation-bridge"
        aria-labelledby="observation-bridge-title"
        id="observation-bridge"
      >
        <div class="section-heading">
          <p>Observation & Care</p>
          <h2 id="observation-bridge-title">관찰과 돌봄으로 남긴 기준</h2>
        </div>
        <p class="observation-bridge__intro">
          만냥구름은 기록실의 장식이 아니라, 문제를 보기 전에 먼저 살피고 원인을 이해하려는 태도를
          매일 확인하게 해주는 존재입니다.
        </p>
        <div class="observation-bridge__grid">
          {
            observationNotes.map((note) => (
              <article>
                <h3>{note.title}</h3>
                <p>{note.description}</p>
              </article>
            ))
          }
        </div>
      </section>

      <section id="cat-profiles" class="cat-profiles" aria-labelledby="cat-profiles-title">
        <div class="section-heading">
          <p>Roommates</p>
          <h2 id="cat-profiles-title">기록실을 함께 쓰는 고양이들</h2>
        </div>
        <div class="cat-profiles__grid">
          {cats.map((cat) => <CatProfileCard cat={cat} />)}
        </div>
      </section>

      <div id="cat-gallery">
        <CatGallery photos={catPhotos} />
      </div>

      <section id="cat-notes" class="cat-notes" aria-labelledby="cat-notes-title">
        <div class="section-heading">
          <p>Observation Log</p>
          <h2 id="cat-notes-title">만냥구름 관찰일지</h2>
        </div>

        {
          observationPosts.length > 0 ? (
            <ul class="cat-notes__list">
              {observationPosts.map((post) => (
                <li>
                  <a href={routes.record(post.id)}>
                    <h3>{post.data.title}</h3>
                    <p>{post.data.description}</p>
                    <time datetime={post.data.pubDate.toISOString()}>
                      <FormattedDate date={post.data.pubDate} />
                    </time>
                  </a>
                </li>
              ))}
            </ul>
          ) : (
            <EmptyState
              eyebrow={uiCopy.emptyDrawer}
              title={uiCopy.emptyDrawerTitle}
              description="아직 만냥구름 관찰일지는 꺼낼 기록이 없습니다. 사진첩을 먼저 보거나 전체 기록에서 다른 서랍을 열어볼 수 있습니다."
              href={routes.records}
              linkLabel="전체 기록 보기"
              compact
            />
          )
        }
      </section>
      <Footer />
    </main>
  </body>
</html>

<style>
  .manyang-page {
    width: min(1080px, calc(100% - 2rem));
    max-width: none;
    padding: 3rem 0 4.5rem;
  }

  .manyang-hero {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(280px, 0.72fr);
    gap: 1.5rem;
    align-items: center;
    margin-bottom: 4rem;
    padding: 1.25rem;
    border-radius: 12px;
    background:
      linear-gradient(135deg, rgba(var(--accent-rgb), 0.13), transparent 36%),
      linear-gradient(180deg, var(--surface-elevated), rgba(var(--sage-rgb), 0.08));
    box-shadow:
      0 0 0 1px rgba(var(--gray-light), 0.34),
      var(--box-shadow);
  }

  .manyang-hero__content {
    padding: 2rem;
  }

  .manyang-hero__eyebrow,
  .section-heading p {
    margin: 0 0 0.35rem;
    color: var(--accent);
    font-size: 0.85rem;
    font-weight: 800;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  .manyang-hero h1 {
    margin-bottom: 1rem;
    font-size: 5rem;
    line-height: 1.02;
  }

  .manyang-hero__content > p {
    max-width: 42rem;
    margin: 0;
    color: rgb(var(--gray));
    font-size: 1.2rem;
    line-height: 1.75;
    text-wrap: balance;
  }

  .manyang-hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    margin-top: 1.4rem;
  }

  .manyang-hero__actions a {
    display: inline-flex;
    padding: 0.45rem 0.85rem;
    border-radius: 999px;
    background: rgba(var(--accent-rgb), 0.12);
    color: var(--accent-dark);
    font-size: 0.9rem;
    font-weight: 800;
    text-decoration: none;
  }

  .manyang-hero__actions a:hover,
  .manyang-hero__actions a:focus-visible {
    background: rgba(var(--accent-rgb), 0.18);
    color: var(--accent);
  }

  .manyang-hero__photo {
    margin: 0;
    overflow: hidden;
    border-radius: 8px;
    background: var(--surface);
    box-shadow: 0 12px 36px rgba(74, 47, 34, 0.18);
    transform: rotate(1deg);
  }

  .manyang-hero__photo :global(img) {
    display: block;
    width: 100%;
    aspect-ratio: 4 / 3;
    border-radius: 0;
    object-fit: cover;
  }

  .manyang-hero__photo figcaption {
    padding: 0.8rem 0.9rem;
    color: rgb(var(--gray));
    font-size: 0.92rem;
    font-weight: 700;
  }

  .section-heading {
    max-width: 48rem;
    margin-bottom: 1.5rem;
  }

  .section-heading h2 {
    margin: 0;
    font-size: 2.65rem;
  }

  .cat-profiles,
  .observation-bridge,
  .cat-notes {
    margin-top: 4rem;
  }

  .observation-bridge__intro {
    max-width: 46rem;
    margin: 0 0 1.25rem;
    color: rgb(var(--gray));
    line-height: 1.75;
    word-break: keep-all;
  }

  .observation-bridge__grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.85rem;
  }

  .observation-bridge__grid article {
    min-width: 0;
    padding: 1rem;
    border-radius: 8px;
    background: var(--surface-elevated);
    box-shadow: 0 0 0 1px rgba(var(--gray-light), 0.34);
  }

  .observation-bridge__grid h3 {
    margin: 0 0 0.55rem;
    font-size: 1.15rem;
    letter-spacing: 0;
  }

  .observation-bridge__grid p {
    margin: 0;
    color: rgb(var(--gray));
    line-height: 1.65;
    word-break: keep-all;
  }

  .cat-profiles__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }

  .cat-notes__list {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .cat-notes__list a {
    display: block;
    height: 100%;
    padding: 1.1rem;
    border-radius: 8px;
    background: var(--surface-elevated);
    color: rgb(var(--gray-dark));
    text-decoration: none;
    box-shadow: 0 0 0 1px rgba(var(--gray-light), 0.34);
  }

  .cat-notes__list a {
    transition:
      transform 0.2s ease,
      box-shadow 0.2s ease;
  }

  .cat-notes__list a:hover,
  .cat-notes__list a:focus-visible {
    transform: translateY(-2px);
    box-shadow: var(--box-shadow);
  }

  .cat-notes__list h3 {
    margin-bottom: 0.65rem;
    font-size: 1.45rem;
  }

  .cat-notes__list p {
    margin: 0 0 0.85rem;
    color: rgb(var(--gray));
    line-height: 1.6;
  }

  .cat-notes__list time {
    color: rgb(var(--gray));
    font-size: 0.9rem;
  }

  @media (max-width: 860px) {
    .manyang-page {
      width: min(100% - 1.5rem, 1080px);
      padding-top: 2rem;
    }

    .manyang-hero {
      grid-template-columns: 1fr;
      margin-bottom: 3rem;
    }

    .manyang-hero__content {
      padding: 0.75rem;
    }

    .manyang-hero h1 {
      font-size: 3.15rem;
    }

    .manyang-hero__content > p {
      font-size: 1.05rem;
    }

    .manyang-hero__photo {
      transform: none;
    }

    .section-heading h2 {
      font-size: 2.15rem;
    }

    .cat-profiles,
    .observation-bridge,
    .cat-notes {
      margin-top: 3rem;
    }

    .observation-bridge__grid {
      grid-template-columns: 1fr;
    }
  }
</style>

---
const destination = '/manyang-gureum/';
---

<!doctype html>
<html lang="ko">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width,initial-scale=1" />
		<meta http-equiv="refresh" content={`0;url=${destination}`} />
		<link rel="canonical" href={destination} />
		<title>만냥구름으로 이동합니다</title>
	</head>
	<body>
		<main>
			<p>
				만냥구름 페이지로 이동합니다.
				<a href={destination}>이동하지 않으면 여기를 눌러주세요.</a>
			</p>
		</main>
	</body>
</html>

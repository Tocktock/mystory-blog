---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import RecordCard from '../../components/records/RecordCard.astro';
import { getCollection, type CollectionEntry } from 'astro:content';
import { SITE_TITLE } from '../../consts';
import { categoryList, type Category } from '../../data/categories';
import { routes } from '../../utils/routes';

type Props = {
  category: Category;
  posts: CollectionEntry<'blog'>[];
};

export async function getStaticPaths() {
  const posts = await getCollection('blog');

  return categoryList
    .map((category) => ({
      category,
      posts: posts
        .filter((post) => post.data.category === category.slug)
        .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()),
    }))
    .filter(({ posts }) => posts.length > 0)
    .map(({ category, posts }) => ({
      params: { slug: category.slug },
      props: { category, posts },
    }));
}

const { category, posts } = Astro.props as Props;
---

<!doctype html>
<html lang="ko">
  <head>
    <BaseHead
      title={`${category.label} 기록 | ${SITE_TITLE}`}
      description={category.description}
      lang="ko"
    />
  </head>
  <body>
    <Header />
    <main class="category-page" aria-labelledby="category-title">
      <header class="category-page__header">
        <p class="category-page__breadcrumbs">
          <a href={routes.records}>기록</a>
          <span aria-hidden="true">/</span>
          <span>{category.label}</span>
        </p>
        <h1 id="category-title">{category.label}</h1>
        <p>{category.description}</p>
      </header>

      <ul class="category-page__list">
        {
          posts.map((post) => (
            <li>
              <RecordCard post={post} showCategory={false} showTags={false} />
            </li>
          ))
        }
      </ul>
      <Footer />
    </main>
  </body>
</html>

<style>
  .category-page {
    width: 960px;
  }

  .category-page__header {
    max-width: 42rem;
    margin: 0 auto 2rem;
    text-align: center;
  }

  .category-page__breadcrumbs {
    display: inline-flex;
    gap: 0.5rem;
    margin: 0 0 0.75rem;
    color: rgb(var(--gray));
    font-size: 0.95rem;
  }

  .category-page__breadcrumbs a {
    color: var(--accent);
    text-decoration: none;
  }

  .category-page__header h1 {
    margin-bottom: 1rem;
  }

  .category-page__header p:last-child {
    margin: 0;
    color: rgb(var(--gray));
    line-height: 1.75;
    text-wrap: balance;
  }

  .category-page__list {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.25rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  @media (max-width: 960px) {
    .category-page {
      width: 100%;
    }
  }
</style>

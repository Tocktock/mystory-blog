---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import HeroSection from '../components/home/HeroSection.astro';
import BookshelfSection from '../components/home/BookshelfSection.astro';
import RecentRecords from '../components/home/RecentRecords.astro';
import ManyangGureumCard from '../components/home/ManyangGureumCard.astro';
import { SITE_AUTHOR, SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { buildPersonJsonLd, buildWebsiteJsonLd } from '../utils/jsonld';

const posts = (await getCollection('blog'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 3);

const siteURL = Astro.site ? new URL(Astro.site) : Astro.url;
const canonicalURL = new URL(Astro.url.pathname, siteURL).toString();
const websiteJsonLd = buildWebsiteJsonLd({
	canonicalUrl: canonicalURL,
	title: SITE_TITLE,
	description: SITE_DESCRIPTION,
	author: SITE_AUTHOR,
});
const personJsonLd = buildPersonJsonLd({
	canonicalUrl: canonicalURL,
	name: SITE_AUTHOR,
	description: SITE_DESCRIPTION,
});
---

<!doctype html>
<html lang="ko">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} lang="ko" />
		<script type="application/ld+json" is:inline set:html={JSON.stringify(websiteJsonLd)} />
		<script type="application/ld+json" is:inline set:html={JSON.stringify(personJsonLd)} />
	</head>
	<body>
		<Header />
		<main class="home-page">
			<HeroSection />
			<BookshelfSection />
			<RecentRecords posts={posts} />
			<ManyangGureumCard />
		</main>
		<Footer />
	</body>
</html>

<style>
	.home-page {
		width: 100%;
		max-width: none;
		padding: 2rem 0 4.5rem;
	}

	@media (max-width: 720px) {
		.home-page {
			padding-top: 0;
			padding-bottom: 3rem;
		}
	}
</style>

---
import { Image } from 'astro:assets';
import type { CatProfile } from '../../data/cats';

interface Props {
  cat: CatProfile;
}

const { cat } = Astro.props as Props;
---

<article class={`cat-profile cat-profile--${cat.id}`}>
  <div class="cat-profile__image-frame">
    <Image
      src={cat.image}
      alt={cat.imageAlt}
      widths={[320, 480, 640, 960]}
      sizes="(max-width: 720px) 100vw, 420px"
      loading="lazy"
      decoding="async"
      class="cat-profile__image"
    />
  </div>

  <div class="cat-profile__body">
    <p class="cat-profile__role">{cat.role}</p>
    <h3>{cat.name}</h3>
    <p class="cat-profile__description">{cat.description}</p>

    <div class="cat-profile__section">
      <h4>성격</h4>
      <ul>
        {cat.personality.map((item) => <li>{item}</li>)}
      </ul>
    </div>

    <div class="cat-profile__section">
      <h4>좋아하는 것</h4>
      <ul>
        {cat.likes.map((item) => <li>{item}</li>)}
      </ul>
    </div>
  </div>
</article>

<style>
  .cat-profile {
    display: grid;
    grid-template-columns: minmax(180px, 0.72fr) minmax(0, 1fr);
    gap: 1rem;
    min-height: 18rem;
    overflow: hidden;
    border-radius: 8px;
    background: var(--surface-elevated);
    box-shadow:
      0 0 0 1px rgba(var(--gray-light), 0.34),
      var(--box-shadow);
  }

  .cat-profile__image-frame {
    position: relative;
    min-height: 100%;
    overflow: hidden;
    background: rgba(var(--accent-rgb), 0.1);
  }

  .cat-profile__image {
    position: absolute;
    inset: 0;
    display: block;
    width: 100%;
    height: 100%;
    border-radius: 0;
    object-fit: cover;
  }

  .cat-profile__body {
    padding: 1.25rem 1.25rem 1.25rem 0;
  }

  .cat-profile__role {
    display: inline-flex;
    margin: 0 0 0.65rem;
    padding: 0.22rem 0.6rem;
    border-radius: 999px;
    background: rgba(var(--accent-rgb), 0.12);
    color: var(--accent-dark);
    font-size: 0.82rem;
    font-weight: 800;
  }

  .cat-profile h3 {
    margin-bottom: 0.75rem;
    font-size: 2.15rem;
  }

  .cat-profile__description {
    margin: 0 0 1rem;
    color: rgb(var(--gray));
    line-height: 1.7;
  }

  .cat-profile__section + .cat-profile__section {
    margin-top: 0.9rem;
  }

  .cat-profile__section h4 {
    margin-bottom: 0.45rem;
    font-size: 1rem;
  }

  .cat-profile__section ul {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .cat-profile__section li {
    display: inline-flex;
    padding: 0.22rem 0.55rem;
    border-radius: 999px;
    background: rgba(var(--gray-light), 0.22);
    color: rgb(var(--gray-dark));
    font-size: 0.86rem;
    font-weight: 700;
  }

  @media (max-width: 720px) {
    .cat-profile {
      grid-template-columns: 1fr;
      min-height: 0;
    }

    .cat-profile h3 {
      font-size: 1.85rem;
    }

    .cat-profile__body {
      padding: 1.1rem;
    }

    .cat-profile__image {
      position: static;
      height: auto;
      aspect-ratio: 4 / 3;
    }
  }
</style>

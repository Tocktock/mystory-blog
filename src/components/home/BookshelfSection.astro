---
import { routes } from '../../utils/routes';

const shelves = [
	{
		title: 'AI & Agent',
		description: '도구를 만들고 실험하며 남긴 기록',
		href: routes.series,
		label: '시리즈 보기',
		tone: 'warm',
	},
	{
		title: 'Backend',
		description: '서버, 구조, 문제 해결에 대한 노트',
		href: routes.category('tech'),
		label: '기술 기록 보기',
		tone: 'ink',
	},
	{
		title: '생각과 일상',
		description: '몰입, 관찰, 배움, 살아가는 방식에 대한 글',
		href: routes.category('thought'),
		label: '생각 보기',
		tone: 'sage',
	},
	{
		title: '만냥구름',
		description: '기록실을 함께 쓰는 두 고양이의 순간들',
		href: routes.manyangGureum,
		label: '만냥구름 보기',
		tone: 'soft',
	},
];
---

<section class="bookshelf" aria-labelledby="bookshelf-title">
	<div class="bookshelf__header">
		<p class="bookshelf__eyebrow">Bookshelf</p>
		<h2 id="bookshelf-title">기록실 책장</h2>
		<p>기술과 생각, 일상과 만냥구름을 각각의 책장에 천천히 꽂아둡니다.</p>
	</div>

	<div class="bookshelf__grid">
		{
			shelves.map((shelf) => (
				<a class:list={['bookshelf__card', `bookshelf__card--${shelf.tone}`]} href={shelf.href}>
					<span class="bookshelf__card-mark" aria-hidden="true" />
					<h3>{shelf.title}</h3>
					<p>{shelf.description}</p>
					<span class="bookshelf__link">
						{shelf.label}
						<span aria-hidden="true">›</span>
					</span>
				</a>
			))
		}
	</div>
</section>

<style>
	.bookshelf {
		width: min(1040px, calc(100% - 2rem));
		margin: 4rem auto 0;
	}

	.bookshelf__header {
		max-width: 42rem;
		margin-bottom: 1.5rem;
	}

	.bookshelf__eyebrow {
		margin: 0 0 0.35rem;
		color: var(--accent);
		font-size: 0.85rem;
		font-weight: 800;
		letter-spacing: 0;
		text-transform: uppercase;
	}

	.bookshelf h2 {
		margin-bottom: 0.75rem;
		font-size: 2.7rem;
	}

	.bookshelf__header p:last-child {
		margin: 0;
		color: rgb(var(--gray));
		line-height: 1.75;
		text-wrap: balance;
	}

	.bookshelf__grid {
		display: grid;
		grid-template-columns: 1.1fr 0.9fr;
		gap: 1rem;
	}

	.bookshelf__card {
		position: relative;
		display: flex;
		min-height: 13.5rem;
		flex-direction: column;
		justify-content: space-between;
		padding: 1.2rem;
		overflow: hidden;
		border-radius: 8px;
		background:
			linear-gradient(180deg, rgba(var(--shelf-tone), 0.1), transparent 48%),
			var(--surface-elevated);
		color: rgb(var(--gray-dark));
		text-decoration: none;
		box-shadow: 0 0 0 1px rgba(var(--gray-light), 0.34);
		transition: transform 0.2s ease, box-shadow 0.2s ease;
	}

	.bookshelf__card--warm {
		--shelf-tone: var(--accent-rgb);
	}

	.bookshelf__card--ink {
		--shelf-tone: var(--ink-rgb);
	}

	.bookshelf__card--sage {
		--shelf-tone: var(--sage-rgb);
	}

	.bookshelf__card--soft {
		--shelf-tone: var(--clay-rgb);
	}

	.bookshelf__card:hover,
	.bookshelf__card:focus-visible {
		box-shadow: var(--box-shadow);
		transform: translateY(-4px);
	}

	.bookshelf__card:active {
		transform: translateY(-1px);
	}

	.bookshelf__card-mark {
		position: absolute;
		top: 0;
		left: 1.2rem;
		width: 2.2rem;
		height: 4.2rem;
		border-radius: 0 0 999px 999px;
		background: rgba(var(--shelf-tone), 0.2);
	}

	.bookshelf__card h3 {
		position: relative;
		margin: 3.2rem 0 0.7rem;
		font-size: 1.6rem;
	}

	.bookshelf__card p {
		position: relative;
		margin: 0;
		color: rgb(var(--gray));
		line-height: 1.65;
	}

	.bookshelf__link {
		position: relative;
		display: inline-flex;
		align-items: center;
		gap: 0.35rem;
		margin-top: 1rem;
		color: var(--accent);
		font-weight: 800;
	}

	.bookshelf__link span {
		font-size: 1.2em;
		line-height: 1;
	}

	@media (max-width: 960px) {
		.bookshelf__grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}

	@media (max-width: 640px) {
		.bookshelf {
			margin-top: 3rem;
		}

		.bookshelf h2 {
			font-size: 2.15rem;
		}

		.bookshelf__grid {
			grid-template-columns: 1fr;
		}

		.bookshelf__card {
			min-height: 12rem;
		}
	}
</style>

---
import { Image } from 'astro:assets';
import heroImage from '../../assets/gallery/main.jpg';
import { routes } from '../../utils/routes';

interface Props {
  recordCount: number;
  seriesCount: number;
  activeSeriesCount: number;
  latestDateLabel: string;
}

const { recordCount, seriesCount, activeSeriesCount, latestDateLabel } = Astro.props as Props;

const heroStats = [
  { label: 'records', value: `${recordCount}편` },
  { label: 'series', value: `${activeSeriesCount}/${seriesCount}` },
  { label: 'latest', value: latestDateLabel },
];
---

<section class="home-hero" aria-labelledby="home-hero-title">
  <div class="home-hero__media">
    <Image
      src={heroImage}
      alt="지용과 고양이들이 함께 머무는 따뜻한 기록실 분위기의 사진"
      widths={[720, 960, 1184, 1440, 1680]}
      sizes="(max-width: 960px) 100vw, 1180px"
      loading="eager"
      decoding="async"
      fetchpriority="high"
      class="home-hero__image"
    />
    <div class="home-hero__overlay">
      <div class="home-hero__layout">
        <div class="home-hero__content">
          <p class="home-hero__eyebrow">Ji Yong's Record Room</p>
          <h1 id="home-hero-title">지용의 기록실</h1>
          <p class="home-hero__description">
            AI, Backend, Agent, 그리고 만냥구름. 배우고 만들고 사랑하는 것들을 기록합니다.
          </p>
          <div class="home-hero__actions" aria-label="홈 주요 이동">
            <a class="home-hero__button home-hero__button--primary" href={routes.records}
              >기록 보기</a
            >
            <a class="home-hero__button" href={routes.series}>시리즈 보기</a>
            <a class="home-hero__button home-hero__button--soft" href={routes.manyangGureum}>
              만냥구름 만나기
              <span aria-hidden="true">›</span>
            </a>
          </div>
        </div>

        <aside class="home-hero__index" aria-label="기록실 현황">
          <p class="home-hero__index-title">현재 책장</p>
          <dl>
            {
              heroStats.map((item) => (
                <div>
                  <dt>{item.label}</dt>
                  <dd>{item.value}</dd>
                </div>
              ))
            }
          </dl>
        </aside>
      </div>
    </div>
  </div>
</section>

<style>
  .home-hero {
    width: min(1180px, calc(100% - 2rem));
    margin: 0 auto;
  }

  .home-hero__media {
    position: relative;
    min-height: min(78dvh, 720px);
    overflow: hidden;
    border-radius: 18px;
    background: var(--surface-elevated);
    box-shadow: var(--box-shadow);
    isolation: isolate;
  }

  .home-hero__image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border-radius: 0;
    object-fit: cover;
    transform: scale(1.02);
  }

  .home-hero__overlay {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: stretch;
    background:
      linear-gradient(
        90deg,
        rgba(36, 28, 22, 0.82) 0%,
        rgba(36, 28, 22, 0.5) 45%,
        rgba(36, 28, 22, 0.12) 100%
      ),
      linear-gradient(180deg, rgba(36, 28, 22, 0.12) 0%, rgba(36, 28, 22, 0.74) 100%);
  }

  .home-hero__layout {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(16rem, 0.34fr);
    gap: 2rem;
    align-items: end;
    width: 100%;
    padding: 3.25rem;
    color: #fff9f0;
  }

  .home-hero__content {
    max-width: 43rem;
    padding-bottom: 1rem;
  }

  .home-hero__eyebrow,
  .home-hero__index-title {
    margin: 0 0 0.75rem;
    color: rgba(255, 249, 240, 0.78);
    font-size: 0.82rem;
    font-weight: 800;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  .home-hero h1 {
    max-width: 10ch;
    margin: 0 0 1rem;
    color: inherit;
    font-size: 6.2rem;
    line-height: 0.98;
    text-wrap: balance;
    text-shadow: 0 18px 44px rgba(0, 0, 0, 0.32);
  }

  .home-hero__description {
    max-width: 34rem;
    margin: 0;
    color: rgba(255, 249, 240, 0.92);
    font-size: 1.18rem;
    line-height: 1.78;
    text-shadow: 0 8px 24px rgba(0, 0, 0, 0.24);
    text-wrap: balance;
  }

  .home-hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 1.6rem;
  }

  .home-hero__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.4rem;
    min-height: 2.85rem;
    padding: 0.65rem 1.15rem;
    border: 1px solid rgba(255, 249, 240, 0.42);
    border-radius: 999px;
    background: rgba(255, 249, 240, 0.12);
    color: #fff9f0;
    font-weight: 800;
    text-decoration: none;
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.16);
    backdrop-filter: blur(12px);
    transition:
      background-color 0.24s ease,
      color 0.24s ease,
      transform 0.24s ease;
  }

  .home-hero__button:hover,
  .home-hero__button:focus-visible {
    background: rgba(255, 249, 240, 0.22);
    transform: translateY(-2px);
  }

  .home-hero__button:active {
    transform: translateY(0);
  }

  .home-hero__button--primary {
    border-color: #fff9f0;
    background: #fff9f0;
    color: #4a2f22;
  }

  .home-hero__button--primary:hover,
  .home-hero__button--primary:focus-visible {
    background: #f7f0e6;
    color: #4a2f22;
  }

  .home-hero__button--soft span {
    font-size: 1.2em;
    line-height: 1;
  }

  .home-hero__index {
    padding: 1rem;
    border: 1px solid rgba(255, 249, 240, 0.18);
    border-radius: 8px;
    background: rgba(255, 249, 240, 0.1);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.14),
      0 18px 40px rgba(0, 0, 0, 0.18);
    backdrop-filter: blur(14px);
  }

  .home-hero__index dl {
    display: grid;
    gap: 0;
    margin: 0;
  }

  .home-hero__index dl > div {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.8rem 0;
    border-top: 1px solid rgba(255, 249, 240, 0.2);
  }

  .home-hero__index dt {
    color: rgba(255, 249, 240, 0.68);
    font-size: 0.8rem;
    font-weight: 800;
    text-transform: uppercase;
  }

  .home-hero__index dd {
    margin: 0;
    color: #fff9f0;
    font-size: 1.25rem;
    font-weight: 800;
    font-variant-numeric: tabular-nums;
  }

  @media (max-width: 920px) {
    .home-hero {
      width: min(100% - 1rem, 1180px);
    }

    .home-hero__media {
      min-height: 78dvh;
    }

    .home-hero__layout {
      grid-template-columns: 1fr;
      gap: 1.25rem;
      align-items: end;
      padding: 2rem;
    }

    .home-hero h1 {
      font-size: 4.3rem;
    }

    .home-hero__index {
      max-width: 30rem;
    }
  }

  @media (max-width: 720px) {
    .home-hero {
      width: 100%;
    }

    .home-hero__media {
      min-height: 82dvh;
      border-radius: 0;
    }

    .home-hero__overlay {
      background: linear-gradient(180deg, rgba(36, 28, 22, 0.18) 0%, rgba(36, 28, 22, 0.86) 100%);
    }

    .home-hero__layout {
      padding: 1.25rem;
    }

    .home-hero h1 {
      font-size: 3.2rem;
    }

    .home-hero__description {
      font-size: 1.05rem;
    }

    .home-hero__actions {
      flex-direction: column;
      align-items: stretch;
    }

    .home-hero__index {
      display: none;
    }
  }
</style>

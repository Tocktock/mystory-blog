---
import type { CollectionEntry } from 'astro:content';
import FormattedDate from '../FormattedDate.astro';
import { getSeries } from '../../data/series';
import { routes } from '../../utils/routes';
import { sortSeriesPosts } from '../../utils/seriesPosts';

interface Props {
  seriesSlug?: string;
  currentId: string;
  posts?: CollectionEntry<'blog'>[];
}

const { seriesSlug, currentId, posts = [] } = Astro.props as Props;

const seriesEntry = getSeries(seriesSlug);
const sortedPosts = [...posts].sort(sortSeriesPosts);
const currentIndex = sortedPosts.findIndex((post) => post.id === currentId);
const currentPosition = currentIndex >= 0 ? currentIndex + 1 : undefined;
const totalPosts = sortedPosts.length;
const progressLabel = currentPosition
  ? `${String(currentPosition).padStart(2, '0')} / ${String(totalPosts).padStart(2, '0')}`
  : undefined;
const previousPost = currentIndex > 0 ? sortedPosts[currentIndex - 1] : undefined;
const nextPost =
  currentIndex >= 0 && currentIndex < sortedPosts.length - 1
    ? sortedPosts[currentIndex + 1]
    : undefined;
---

{
  seriesEntry && sortedPosts.length > 0 && (
    <section class="series-progress" aria-labelledby="series-progress-title">
      <header class="series-progress__header">
        <div class="series-progress__heading">
          <p class="series-progress__eyebrow">Series</p>
          <h2 id="series-progress-title">{seriesEntry.title}</h2>
          <p>
            이 글은 "{seriesEntry.title}" 시리즈의{' '}
            {currentPosition ? `${currentPosition}번째` : '한'} 기록입니다.
          </p>
        </div>
        {progressLabel && <span class="series-progress__count">{progressLabel}</span>}
      </header>

      {(previousPost || nextPost) && (
        <nav class="series-progress__nav" aria-label="시리즈 이전 다음 기록">
          {previousPost ? (
            <a href={routes.record(previousPost.id)} class="series-progress__nav-link">
              <span>이전 기록</span>
              <strong>{previousPost.data.title}</strong>
            </a>
          ) : (
            <span class="series-progress__nav-link series-progress__nav-link--empty">
              <span>이전 기록</span>
              <strong>첫 번째 기록입니다</strong>
            </span>
          )}

          {nextPost ? (
            <a href={routes.record(nextPost.id)} class="series-progress__nav-link">
              <span>다음 기록</span>
              <strong>{nextPost.data.title}</strong>
            </a>
          ) : (
            <span class="series-progress__nav-link series-progress__nav-link--empty">
              <span>다음 기록</span>
              <strong>마지막 기록</strong>
            </span>
          )}
        </nav>
      )}

      <ol class="series-progress__list">
        {sortedPosts.map((post, index) => {
          const isCurrent = post.id === currentId;
          const order = post.data.seriesOrder ?? index + 1;

          return (
            <li
              class:list={[
                'series-progress__item',
                { 'series-progress__item--current': isCurrent },
              ]}
            >
              <a href={routes.record(post.id)} aria-current={isCurrent ? 'page' : undefined}>
                <span class="series-progress__order">{String(order).padStart(2, '0')}</span>
                <span class="series-progress__content">
                  <strong>{post.data.title}</strong>
                  <FormattedDate date={post.data.pubDate} />
                </span>
              </a>
            </li>
          );
        })}
      </ol>

      <a class="series-progress__all" href={routes.seriesDetail(seriesEntry.slug)}>
        시리즈 전체 보기
      </a>
    </section>
  )
}

<style>
  .series-progress {
    margin: 3rem 0 0;
    padding: clamp(1.75rem, 4vw, 2.5rem) 0 0;
    border-top: 1px solid rgba(var(--gray-light), 0.18);
    background: transparent;
  }

  .series-progress__header {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 1rem;
    align-items: start;
    margin-bottom: clamp(1.25rem, 3vw, 1.8rem);
  }

  .series-progress__heading {
    min-width: 0;
  }

  .series-progress__eyebrow {
    margin: 0 0 0.35rem;
    color: var(--accent);
    font-size: 0.82rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .series-progress__header h2 {
    margin: 0 0 0.55rem;
    font-size: clamp(1.35rem, 2vw, 1.75rem);
    line-height: 1.2;
  }

  .series-progress__header p {
    margin: 0;
    color: rgb(var(--gray));
    line-height: 1.65;
  }

  .series-progress__count {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 4.6rem;
    padding: 0.34rem 0.58rem;
    border: 1px solid rgba(var(--accent-rgb), 0.34);
    border-radius: 999px;
    color: var(--accent-dark);
    font-size: 0.78rem;
    font-weight: 800;
    font-variant-numeric: tabular-nums;
    line-height: 1;
    white-space: nowrap;
  }

  .series-progress__nav {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    margin-bottom: clamp(1.35rem, 3vw, 1.9rem);
    border-top: 1px solid rgba(var(--gray-light), 0.12);
    border-bottom: 1px solid rgba(var(--gray-light), 0.12);
  }

  .series-progress__nav-link {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    min-width: 0;
    padding: 0.95rem 1rem;
    background: transparent;
    color: rgb(var(--gray-dark));
    text-decoration: none;
    transition:
      background-color 0.18s ease,
      color 0.18s ease;
  }

  .series-progress__nav-link + .series-progress__nav-link {
    border-left: 1px solid rgba(var(--gray-light), 0.12);
  }

  .series-progress__nav-link span {
    color: rgb(var(--gray));
    font-size: 0.82rem;
    font-weight: 700;
  }

  .series-progress__nav-link strong {
    overflow-wrap: anywhere;
    line-height: 1.35;
  }

  .series-progress__nav-link:hover,
  .series-progress__nav-link:focus-visible {
    background: rgba(var(--accent-rgb), 0.12);
    color: var(--accent);
  }

  .series-progress__nav-link--empty {
    color: rgb(var(--gray));
    opacity: 0.78;
  }

  .series-progress__list {
    display: flex;
    flex-direction: column;
    gap: 0;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .series-progress__item a {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.75rem;
    align-items: center;
    padding: 0.9rem 0;
    border-radius: 0;
    color: rgb(var(--gray-dark));
    text-decoration: none;
    transition:
      background-color 0.18s ease,
      color 0.18s ease,
      padding-left 0.18s ease;
  }

  .series-progress__item + .series-progress__item a {
    border-top: 1px solid rgba(var(--gray-light), 0.1);
  }

  .series-progress__item a:hover,
  .series-progress__item a:focus-visible {
    background: rgba(var(--accent-rgb), 0.12);
    padding-left: 0.65rem;
  }

  .series-progress__item--current a {
    padding-left: 0.65rem;
    border-radius: 0 0.65rem 0.65rem 0;
    background: linear-gradient(90deg, rgba(var(--accent-rgb), 0.14), transparent 78%);
    box-shadow: inset 3px 0 0 var(--accent);
  }

  .series-progress__order {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    border-radius: 999px;
    background: rgba(var(--accent-rgb), 0.12);
    color: var(--accent-dark);
    font-size: 0.82rem;
    font-weight: 800;
  }

  .series-progress__content {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    min-width: 0;
  }

  .series-progress__content strong {
    line-height: 1.35;
  }

  .series-progress__content time {
    color: rgb(var(--gray));
    font-size: 0.88rem;
  }

  .series-progress__all {
    display: inline-flex;
    margin-top: 1.35rem;
    color: var(--accent);
    font-weight: 800;
    text-decoration: none;
  }

  .series-progress__all::after {
    margin-left: 0.35rem;
    content: '→';
    transition: transform 0.18s ease;
  }

  .series-progress__all:hover::after,
  .series-progress__all:focus-visible::after {
    transform: translateX(3px);
  }

  @media (max-width: 640px) {
    .series-progress__header {
      grid-template-columns: 1fr;
      gap: 0.85rem;
    }

    .series-progress__count {
      justify-self: start;
    }

    .series-progress__nav {
      grid-template-columns: 1fr;
    }

    .series-progress__nav-link + .series-progress__nav-link {
      border-top: 1px solid rgba(var(--gray-light), 0.12);
      border-left: 0;
    }
  }
</style>

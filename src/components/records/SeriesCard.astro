---
import type { SeriesEntry } from '../../data/series';
import { getCategory } from '../../data/categories';
import { getSeriesStatusLabel } from '../../data/series';
import { routes } from '../../utils/routes';

interface Props {
  seriesItem: SeriesEntry;
  count: number;
}

const { seriesItem, count } = Astro.props as Props;
const category = getCategory(seriesItem.category);
const statusLabel = getSeriesStatusLabel(seriesItem.status);
const intentItems = [
  seriesItem.purpose?.trim()
    ? { label: '왜 이 선반인가', value: seriesItem.purpose.trim() }
    : undefined,
  seriesItem.readingPromise?.trim()
    ? { label: '읽고 나면', value: seriesItem.readingPromise.trim() }
    : undefined,
].filter((item): item is { label: string; value: string } => Boolean(item));
---

<a
  class="series-card"
  href={routes.seriesDetail(seriesItem.slug)}
  data-series-status={seriesItem.status}
>
  <div class="series-card__meta" aria-label="시리즈 정보">
    <span>{category.label}</span>
    <span>{count}개 기록</span>
    {statusLabel && <span class="series-card__status">{statusLabel}</span>}
  </div>
  <h2>{seriesItem.title}</h2>
  <p class="series-card__description">{seriesItem.description}</p>
  {
    intentItems.length > 0 && (
      <dl class="series-card__intent" aria-label="시리즈 선반 안내">
        {intentItems.map((item) => (
          <div>
            <dt>{item.label}</dt>
            <dd>{item.value}</dd>
          </div>
        ))}
      </dl>
    )
  }
</a>

<style>
  .series-card {
    display: grid;
    grid-template-rows: auto auto auto 1fr;
    height: 100%;
    padding: 1.25rem;
    border-radius: 12px;
    background: var(--room-surface);
    color: var(--ink-text);
    text-decoration: none;
    box-shadow: 0 0 0 1px rgba(var(--gray-light), 0.24);
    transition:
      box-shadow var(--motion-fast) ease,
      transform var(--motion-fast) ease,
      background-color var(--motion-fast) ease;
  }

  .series-card:hover,
  .series-card:focus-visible {
    background-color: rgba(var(--room-accent-rgb), 0.06);
    box-shadow: var(--room-shadow);
    transform: translateY(-2px);
  }

  .series-card__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    margin-bottom: 0.85rem;
  }

  .series-card__meta span {
    display: inline-flex;
    align-items: center;
    padding: 0.2rem 0.55rem;
    border-radius: 999px;
    background: rgba(var(--room-accent-rgb), 0.12);
    color: var(--accent-dark);
    font-size: 0.82rem;
    font-weight: 700;
    line-height: 1.2;
  }

  .series-card__meta .series-card__status {
    background: rgba(var(--ops-sage-rgb), 0.14);
    color: rgb(var(--gray-dark));
  }

  .series-card h2 {
    margin: 0 0 0.75rem;
    color: rgb(var(--black));
    font-size: clamp(1.35rem, 2vw, 1.7rem);
    line-height: 1.2;
  }

  .series-card__description {
    margin: 0 0 0.9rem;
    color: var(--ink-muted);
    line-height: 1.65;
  }

  .series-card__intent {
    display: grid;
    gap: 0.65rem;
    align-self: end;
    margin: 0;
    padding: 0.8rem;
    border-radius: 8px;
    background: rgba(var(--gray-light), 0.14);
  }

  .series-card__intent div {
    display: grid;
    gap: 0.18rem;
  }

  .series-card__intent dt {
    color: var(--accent);
    font-size: 0.76rem;
    font-weight: 800;
  }

  .series-card__intent dd {
    margin: 0;
    color: var(--ink-text);
    font-size: 0.92rem;
    line-height: 1.55;
  }
</style>

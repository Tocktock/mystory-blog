---
import { careerEntries, careerProfile } from '../../data/career';

const entries = careerEntries.map((entry) => ({
  ...entry,
  details: entry.details.flatMap((group) => group.items),
}));
---

<section
  class="career-timeline career-section"
  id="career-timeline"
  aria-labelledby="career-timeline-title"
>
  <header class="career-timeline__header">
    <h2 id="career-timeline-title">경력</h2>
  </header>
  <div class="career-timeline__list">
    {
      entries.map((entry) => (
        <article class="career-timeline__entry">
          <div class="career-timeline__meta">
            <p>{entry.period}</p>
            <h3>{entry.company}</h3>
            <span>
              {entry.role} · {entry.position}
            </span>
          </div>
          <div class="career-timeline__body">
            <h3>{entry.headline}</h3>
            <div class="career-timeline__summary">
              <p>{entry.summary}</p>
              <p>{careerProfile.workStyle}</p>
            </div>
            {entry.highlights.length > 0 ? (
              <ul>
                {entry.highlights.map((highlight) => (
                  <li>{highlight}</li>
                ))}
              </ul>
            ) : null}
            <dl class="career-timeline__facts">
              {entry.details.map((detail) => (
                <div>
                  <dt>{detail.label}</dt>
                  <dd>{detail.value}</dd>
                </div>
              ))}
            </dl>
          </div>
        </article>
      ))
    }
  </div>
</section>

<style>
  .career-timeline__header {
    display: block;
    margin-bottom: clamp(1.7rem, 4vw, 2.5rem);
  }

  .career-timeline h2 {
    margin: 0;
    color: var(--career-ink);
    font-size: clamp(2rem, 4vw, 3rem);
    letter-spacing: 0;
  }

  .career-timeline__list {
    display: grid;
  }

  .career-timeline__entry {
    display: grid;
    grid-template-columns: minmax(15rem, 0.32fr) minmax(0, 1fr);
    gap: clamp(1.5rem, 4vw, 4rem);
    padding: clamp(2rem, 5vw, 3rem) 0;
  }

  .career-timeline__entry + .career-timeline__entry {
    border-top: 1px solid color-mix(in srgb, var(--career-line) 78%, transparent);
  }

  .career-timeline__meta p {
    margin: 0 0 0.75rem;
    color: var(--career-muted-strong);
    font-size: 0.86rem;
    font-weight: 800;
    letter-spacing: 0.04em;
    font-variant-numeric: tabular-nums;
  }

  .career-timeline__meta h3 {
    margin: 0;
    color: var(--career-ink);
    font-size: clamp(1.35rem, 2.5vw, 2rem);
    letter-spacing: 0;
    word-break: keep-all;
  }

  .career-timeline__meta span {
    display: block;
    margin-top: 0.55rem;
    color: var(--career-muted-strong);
    font-size: 0.98rem;
    font-weight: 700;
    line-height: 1.55;
    word-break: keep-all;
  }

  .career-timeline__body {
    display: grid;
    gap: clamp(1rem, 2.5vw, 1.35rem);
    max-width: 48rem;
  }

  .career-timeline__body h3 {
    max-width: 28ch;
    margin: 0;
    color: var(--career-ink);
    font-size: clamp(1.55rem, 3vw, 2.1rem);
    font-weight: 900;
    letter-spacing: 0;
    line-height: 1.22;
    word-break: keep-all;
  }

  .career-timeline__summary {
    display: grid;
    gap: 0.55rem;
    max-width: 45rem;
  }

  .career-timeline__summary p {
    margin: 0;
    color: var(--career-muted);
    font-size: clamp(1.04rem, 1.75vw, 1.12rem);
    line-height: 1.72;
    word-break: keep-all;
  }

  :global(.career-timeline ul) {
    display: grid;
    gap: 0.55rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  :global(.career-timeline li) {
    position: relative;
    padding-left: 1rem;
    color: var(--career-ink);
    font-size: 0.98rem;
    font-weight: 800;
    line-height: 1.55;
    word-break: keep-all;
  }

  :global(.career-timeline li::before) {
    position: absolute;
    top: 0.72em;
    left: 0;
    width: 0.35rem;
    height: 0.35rem;
    border-radius: 999px;
    background: var(--career-accent);
    content: '';
  }

  .career-timeline__facts {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(10rem, max-content));
    gap: 0.85rem clamp(1rem, 3vw, 1.75rem);
    justify-content: start;
    margin: 0.25rem 0 0;
  }

  :global(.career-timeline__facts div) {
    display: grid;
    gap: 0.2rem;
    min-width: 0;
  }

  :global(.career-timeline__facts dt) {
    margin: 0;
    color: var(--career-muted-strong);
    font-size: 0.74rem;
    font-weight: 800;
    letter-spacing: 0.04em;
    line-height: 1.45;
  }

  :global(.career-timeline__facts dd) {
    margin: 0;
    color: var(--career-accent-strong);
    font-size: 0.95rem;
    font-weight: 800;
    line-height: 1.45;
    word-break: keep-all;
  }

  @media (max-width: 760px) {
    .career-timeline__entry {
      grid-template-columns: 1fr;
    }

    .career-timeline__entry {
      gap: 1.25rem;
    }
  }
</style>

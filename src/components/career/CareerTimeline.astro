---
import { careerEntries, careerProfile } from '../../data/career';

const entries = careerEntries.map((entry) => ({
  ...entry,
  details: entry.details.flatMap((group) => group.items),
}));
---

<section
  class="career-timeline career-section"
  id="career-timeline"
  aria-labelledby="career-timeline-title"
>
  <header class="career-timeline__header">
    <h2 id="career-timeline-title">경력</h2>
  </header>
  <div class="career-timeline__list">
    {
      entries.map((entry) => (
        <article class="career-timeline__entry">
          <div class="career-timeline__meta">
            <p>{entry.period}</p>
            <h3>{entry.company}</h3>
            <span>
              {entry.role} · {entry.position}
            </span>
          </div>
          <div class="career-timeline__body">
            <section class="career-timeline__section">
              <h4>맡은 일</h4>
              <p>{entry.summary}</p>
            </section>
            <section class="career-timeline__section">
              <h4>주요 범위</h4>
              <dl class="career-timeline__facts">
                {entry.details.map((detail) => (
                  <div>
                    <dt>{detail.label}</dt>
                    <dd>{detail.value}</dd>
                  </div>
                ))}
              </dl>
            </section>
            <section class="career-timeline__section">
              <h4>작업 방식</h4>
              <p>
                <strong>일하는 기준</strong>
                {' '}
                {careerProfile.workStyle}
              </p>
              {entry.highlights.length > 0 ? (
                <ul>
                  {entry.highlights.map((highlight) => (
                    <li>{highlight}</li>
                  ))}
                </ul>
              ) : null}
            </section>
          </div>
        </article>
      ))
    }
  </div>
</section>

<style>
  .career-timeline__header {
    display: block;
    margin-bottom: clamp(1.7rem, 4vw, 2.5rem);
  }

  .career-timeline h2 {
    margin: 0;
    color: var(--career-ink);
    font-size: clamp(2rem, 4vw, 3rem);
    letter-spacing: 0;
  }

  .career-timeline__list {
    display: grid;
  }

  .career-timeline__entry {
    display: grid;
    grid-template-columns: minmax(15rem, 0.32fr) minmax(0, 1fr);
    gap: clamp(1.5rem, 4vw, 4rem);
    padding: clamp(2rem, 5vw, 3rem) 0;
  }

  .career-timeline__entry + .career-timeline__entry {
    border-top: 1px solid color-mix(in srgb, var(--career-line) 78%, transparent);
  }

  .career-timeline__meta p {
    margin: 0 0 0.75rem;
    color: var(--career-muted-strong);
    font-size: 0.86rem;
    font-weight: 800;
    letter-spacing: 0.04em;
    font-variant-numeric: tabular-nums;
  }

  .career-timeline__meta h3 {
    margin: 0;
    color: var(--career-ink);
    font-size: clamp(1.35rem, 2.5vw, 2rem);
    letter-spacing: 0;
    word-break: keep-all;
  }

  .career-timeline__meta span {
    display: block;
    margin-top: 0.55rem;
    color: var(--career-muted-strong);
    font-size: 0.98rem;
    font-weight: 700;
    line-height: 1.55;
    word-break: keep-all;
  }

  .career-timeline__body {
    display: grid;
    gap: 1.3rem;
    max-width: 48rem;
  }

  .career-timeline__section {
    display: grid;
    margin: 0;
    gap: 0.55rem;
  }

  .career-timeline__section h4 {
    margin: 0;
    color: var(--career-ink);
    font-size: clamp(1.06rem, 1.8vw, 1.18rem);
    font-weight: 900;
    letter-spacing: 0;
    line-height: 1.45;
    word-break: keep-all;
  }

  .career-timeline__section p {
    margin: 0;
    color: var(--career-muted);
    font-size: clamp(1rem, 1.7vw, 1.1rem);
    line-height: 1.75;
    word-break: keep-all;
  }

  .career-timeline__section p strong {
    color: var(--career-ink);
    font-weight: 900;
  }

  .career-timeline__facts {
    display: grid;
    gap: 0.45rem;
    margin: 0;
  }

  .career-timeline__facts div {
    display: grid;
    grid-template-columns: 5.25rem minmax(0, 1fr);
    gap: 0.8rem;
    align-items: baseline;
  }

  .career-timeline__facts dt {
    margin: 0;
    color: var(--career-muted-strong);
    font-size: 0.86rem;
    font-weight: 900;
    line-height: 1.55;
  }

  .career-timeline__facts dd {
    margin: 0;
    color: var(--career-ink);
    font-size: 0.98rem;
    font-weight: 800;
    line-height: 1.6;
    word-break: keep-all;
  }

  .career-timeline ul {
    display: grid;
    gap: 0.45rem;
    margin: 0.15rem 0 0;
    padding: 0;
    list-style: none;
  }

  .career-timeline li {
    position: relative;
    padding-left: 0.95rem;
    color: var(--career-muted);
    font-size: 0.98rem;
    line-height: 1.68;
    word-break: keep-all;
  }

  .career-timeline li::before {
    position: absolute;
    top: 0.78em;
    left: 0;
    width: 0.28rem;
    height: 0.28rem;
    border-radius: 999px;
    background: var(--career-accent);
    content: '';
  }

  @media (max-width: 760px) {
    .career-timeline__entry {
      grid-template-columns: 1fr;
    }

    .career-timeline__entry {
      gap: 1.25rem;
    }

    .career-timeline__facts div {
      grid-template-columns: 1fr;
      gap: 0.1rem;
    }
  }
</style>

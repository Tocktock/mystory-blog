---
import { isSafeHref } from '../../utils/safeHref';

interface Props {
  href: string;
  external?: boolean;
  class?: string;
  dataExternal?: string;
}

const { href, external = false, class: className, dataExternal } = Astro.props as Props;

if (!isSafeHref(href)) {
  throw new Error(`Unsafe career link href: ${href}`);
}
---

<a
  href={href}
  class={className}
  data-external={dataExternal}
  target={external ? '_blank' : undefined}
  rel={external ? 'noopener noreferrer' : undefined}
>
  <slot />
</a>

---
import { careerLinks } from '../../data/career';

const relatedLinks = careerLinks.links.map((link) => ({
  ...link,
  external: 'external' in link ? link.external : false,
}));
---

<section class="career-links" id="career-related-links" aria-labelledby="career-links-title">
  <h2 id="career-links-title" class="sr-only">관련 링크</h2>
  <nav class="career-links__actions" aria-label="관련 링크">
    {
      relatedLinks.map((link) => (
        <a
          href={link.href}
          target={link.external ? '_blank' : undefined}
          rel={link.external ? 'noopener noreferrer' : undefined}
        >
          <span class="career-links__icon" aria-hidden="true">
            {link.label === 'GitHub' ? (
              <svg viewBox="0 0 16 16" focusable="false">
                <path
                  fill="currentColor"
                  d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"
                />
              </svg>
            ) : (
              <svg viewBox="0 0 24 24" fill="none" focusable="false">
                <path
                  d="M7 5.75h10M7 12h10M7 18.25h6"
                  stroke="currentColor"
                  stroke-linecap="round"
                  stroke-width="2"
                />
              </svg>
            )}
          </span>
          <span>{link.label}</span>
        </a>
      ))
    }
  </nav>
</section>

<style>
  .career-links {
    width: min(1120px, calc(100% - 2rem));
    margin: 0 auto;
    padding: clamp(2.2rem, 6vw, 4rem) 0 0;
    border-top: 1px solid var(--career-line);
  }

  .career-links__actions {
    display: flex;
    flex-wrap: wrap;
    gap: clamp(1rem, 3vw, 1.6rem);
    justify-content: flex-end;
  }

  .career-links__actions a {
    display: inline-flex;
    align-items: center;
    gap: 0.7rem;
    color: var(--career-accent-strong);
    font-size: clamp(1.08rem, 2vw, 1.35rem);
    font-weight: 800;
    line-height: 1.45;
    text-decoration: none;
    transition:
      color 0.2s ease,
      transform 0.2s ease;
  }

  .career-links__icon {
    display: inline-grid;
    width: clamp(2.1rem, 4vw, 2.75rem);
    height: clamp(2.1rem, 4vw, 2.75rem);
    place-items: center;
    color: currentColor;
  }

  .career-links__icon svg {
    width: 100%;
    height: 100%;
    display: block;
  }

  .career-links__actions a:hover,
  .career-links__actions a:focus-visible {
    transform: translate(2px, -2px);
    text-decoration: underline;
    text-underline-offset: 0.22em;
  }

  @media (max-width: 760px) {
    .career-links__actions {
      justify-content: flex-start;
    }
  }
</style>

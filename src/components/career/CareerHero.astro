---
import { careerProfile } from '../../data/career';

const heroActions = careerProfile.actions.map((action) => ({
  label: action.label,
  href: 'href' in action ? action.href : undefined,
  external: 'external' in action ? action.external : undefined,
}));
---

<section class="career-hero" aria-labelledby="career-title">
  <div class="career-hero__layout">
    <div class="career-hero__content">
      <div class="career-hero__identity">
        <p class="career-hero__eyebrow">{careerProfile.eyebrow}</p>
        <p class="career-hero__role">{careerProfile.role}</p>
      </div>
      <h1 id="career-title">{careerProfile.thesis}</h1>
      <div class="career-hero__summary">
        {careerProfile.summary.map((paragraph) => <p>{paragraph}</p>)}
      </div>
    </div>
    <aside class="career-hero__panel" aria-label="이력 요약">
      <dl>
        {
          careerProfile.overview.map((item) => (
            <div>
              <dt>{item.label}</dt>
              <dd>{item.value}</dd>
            </div>
          ))
        }
      </dl>
      <p class="career-hero__meta">{careerProfile.meta.join(' · ')}</p>
      <nav class="career-hero__actions" aria-label="주요 링크">
        {
          heroActions.map((action) => (
            <a
              href={action.href}
              data-external={action.external ? 'true' : 'false'}
              target={action.external ? '_blank' : undefined}
              rel={action.external ? 'noopener noreferrer' : undefined}
            >
              {action.label}
            </a>
          ))
        }
      </nav>
    </aside>
  </div>
</section>

<script>
  const careerHeroActions = document.querySelector('.career-hero__actions');
  const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)');
  let careerHeroScrollFrame = 0;

  const focusCareerSection = (target: HTMLElement) => {
    if (!target.hasAttribute('tabindex')) {
      target.setAttribute('tabindex', '-1');
    }
    target.focus({ preventScroll: true });
  };

  const updateCareerHash = (hash: string) => {
    if (window.location.hash !== hash) {
      history.pushState(null, '', hash);
    }
  };

  const scrollCareerSection = (target: HTMLElement, hash: string) => {
    cancelAnimationFrame(careerHeroScrollFrame);

    const topOffset = 28;
    const start = window.scrollY;
    const destination = Math.max(0, start + target.getBoundingClientRect().top - topOffset);
    const distance = destination - start;

    if (reducedMotion.matches || Math.abs(distance) < 8) {
      window.scrollTo(0, destination);
      updateCareerHash(hash);
      focusCareerSection(target);
      return;
    }

    const duration = Math.min(420, Math.max(240, Math.abs(distance) * 0.22));
    const startedAt = performance.now();
    const easeOutCubic = (progress: number) => 1 - Math.pow(1 - progress, 3);

    const tick = (currentTime: number) => {
      const progress = Math.min((currentTime - startedAt) / duration, 1);
      window.scrollTo(0, start + distance * easeOutCubic(progress));

      if (progress < 1) {
        careerHeroScrollFrame = requestAnimationFrame(tick);
        return;
      }

      updateCareerHash(hash);
      focusCareerSection(target);
    };

    careerHeroScrollFrame = requestAnimationFrame(tick);
  };

  careerHeroActions?.addEventListener('click', (event) => {
    if (!(event.target instanceof HTMLElement)) {
      return;
    }

    const link = event.target.closest<HTMLAnchorElement>('a[href^="#"]');
    if (!link || !careerHeroActions.contains(link)) {
      return;
    }

    const hash = link.getAttribute('href');
    if (!hash || hash === '#') {
      return;
    }

    const target = document.getElementById(decodeURIComponent(hash.slice(1)));
    if (!target) {
      return;
    }

    event.preventDefault();
    scrollCareerSection(target, hash);
  });
</script>

<style>
  .career-hero {
    width: min(1120px, calc(100% - 2rem));
    margin: 0 auto;
    padding: clamp(4rem, 8vw, 6rem) 0 clamp(3rem, 6vw, 4.8rem);
  }

  .career-hero__layout {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(18rem, 0.38fr);
    gap: clamp(2.5rem, 7vw, 5rem);
    align-items: start;
  }

  .career-hero__content {
    max-width: 46rem;
  }

  .career-hero__identity {
    display: grid;
    gap: 0.6rem;
    padding-top: 1.35rem;
    border-top: 1px solid color-mix(in srgb, var(--career-line) 72%, transparent);
  }

  .career-hero__eyebrow {
    margin: 0;
    color: var(--career-ink);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.11em;
    text-transform: uppercase;
  }

  .career-hero__role {
    margin: 0;
    color: var(--career-muted);
    font-size: clamp(0.98rem, 1.6vw, 1.12rem);
    font-weight: 700;
    line-height: 1.55;
    word-break: keep-all;
  }

  .career-hero h1 {
    max-width: 13ch;
    margin: clamp(2rem, 5vw, 3.3rem) 0 0;
    color: var(--career-ink);
    font-size: clamp(2.85rem, 5.2vw, 4.1rem);
    line-height: 1.08;
    letter-spacing: 0;
    word-break: keep-all;
  }

  .career-hero__summary {
    max-width: 43rem;
    margin-top: clamp(1.5rem, 3vw, 2rem);
  }

  .career-hero__summary p {
    margin: 0;
    color: var(--career-muted);
    font-size: clamp(1.02rem, 1.7vw, 1.13rem);
    line-height: 1.75;
    word-break: keep-all;
  }

  .career-hero__summary p + p {
    margin-top: 0.7rem;
  }

  .career-hero__panel {
    display: grid;
    gap: 1.35rem;
    padding: 1.35rem 0 0;
    border-top: 1px solid var(--career-line);
  }

  .career-hero__panel dl {
    display: grid;
    gap: 1.15rem;
    margin: 0;
  }

  .career-hero__panel div {
    display: grid;
    gap: 0.35rem;
  }

  .career-hero__panel dt {
    color: var(--career-muted);
    font-size: 0.76rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    line-height: 1.4;
  }

  .career-hero__panel dd {
    margin: 0;
    color: var(--career-ink);
    font-size: 0.96rem;
    font-weight: 800;
    line-height: 1.55;
    word-break: keep-all;
  }

  .career-hero__meta {
    margin: 0;
    color: var(--career-muted);
    font-size: 0.82rem;
    font-weight: 800;
    line-height: 1.65;
    word-break: keep-all;
  }

  .career-hero__actions {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.4rem;
    width: min(100%, 18rem);
    margin: 0;
  }

  .career-hero__actions a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 1.8rem;
    padding: 0.32rem 0.58rem;
    border: 1px solid color-mix(in srgb, var(--career-line) 76%, transparent);
    border-radius: 7px;
    background: color-mix(in srgb, var(--career-ink) 3%, transparent);
    box-shadow: inset 0 1px 0 color-mix(in srgb, var(--career-ink) 6%, transparent);
    color: color-mix(in srgb, var(--career-ink) 82%, var(--career-muted));
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.01em;
    line-height: 1;
    text-decoration: none;
    white-space: nowrap;
    transition:
      border-color 0.2s ease,
      background-color 0.2s ease,
      color 0.2s ease,
      transform 0.2s ease;
  }

  .career-hero__actions a:hover,
  .career-hero__actions a:focus-visible {
    border-color: color-mix(in srgb, var(--career-accent-strong) 42%, var(--career-line));
    background: color-mix(in srgb, var(--career-accent-strong) 10%, transparent);
    color: var(--career-accent-strong);
    transform: translateY(-1px);
  }

  .career-hero__actions a:focus-visible {
    outline: 2px solid color-mix(in srgb, var(--career-accent-strong) 54%, transparent);
    outline-offset: 3px;
  }

  .career-hero__actions a:active {
    transform: translateY(0);
  }

  @media (max-width: 860px) {
    .career-hero__layout {
      grid-template-columns: 1fr;
      gap: clamp(2rem, 7vw, 3rem);
    }

    .career-hero__panel {
      max-width: 42rem;
    }
  }
</style>
